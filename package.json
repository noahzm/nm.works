{
  "name": "astro-app",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "npm run check:site && astro build",
    "preview": "npm run build && wrangler dev",
    "astro": "astro",
    "check:site": "node scripts/check-site-invariants.mjs",
    "lint": "eslint \"**/*.{ts,astro}\"",
    "format": "prettier --write \"**/*.{ts,astro}\"",
    "format:check": "prettier --check \"**/*.{ts,astro}\"",
    "typecheck": "astro check",
    "generate-types": "wrangler types",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.2",
    "@fontsource-variable/archivo": "^5.2.8",
    "@iconify-json/lucide": "^1.2.114",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^7.0.7",
    "astro-icon": "^1.1.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "sharp": "^0.35.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.16",
    "wrangler": "^4.109.0"
  },
  "overrides": {
    "yaml": "^2.9.0"
  }
}
