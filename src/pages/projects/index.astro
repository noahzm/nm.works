---
import Layout from "@/layouts/main.astro"
import ProjectPreview from "@/components/ProjectPreview.astro"
import ProjectDisciplines from "@/components/ProjectDisciplines.astro"
import { Badge } from "@/components/ui/badge"
import { Separator } from "@/components/ui/separator"
import {
  publishedCaseStudies,
  upcomingCaseStudies,
  visualWork,
} from "@/data/projects"
---

<Layout
  title="Projects · Noah Michaels"
  description="Case studies in product UI, information architecture, print and variable-data systems, and shipped front-end code by Noah Michaels."
>
  <div class="mx-auto max-w-3xl px-6 pt-4 pb-14">
    <section aria-labelledby="case-studies-title">
      <h1 id="case-studies-title" class="text-2xl font-bold tracking-tight">
        Case studies
      </h1>
      <div class="mt-8 divide-y">
        {
          publishedCaseStudies.map((project) => (
            <a
              href={`/projects/${project.slug}`}
              aria-label={`View ${project.title}`}
              class="group grid gap-6 rounded-sm py-8 focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-4 focus-visible:outline-none md:grid-cols-[14rem_1fr]"
            >
              <ProjectPreview
                project={project}
                widths={[360, 600]}
                sizes="(min-width: 768px) 224px, 100vw"
              />
              <div>
                <div class="mb-3 flex flex-wrap items-center gap-x-3 gap-y-2">
                  <ProjectDisciplines
                    disciplines={project.disciplines}
                    label={`${project.title} disciplines`}
                  />
                </div>
                <h3 class="text-xl font-bold tracking-tight group-hover:underline">
                  {project.title}
                </h3>
                <p class="mt-3 max-w-2xl text-sm leading-relaxed text-muted-foreground">
                  {project.summary}
                </p>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    {
      upcomingCaseStudies.length > 0 && (
        <section class="mt-14 pt-12" aria-labelledby="upcoming-title">
          <Separator className="-mt-12 mb-12" />
          <h2 id="upcoming-title" class="text-2xl font-bold tracking-tight">
            In progress
          </h2>
          <p class="mt-3 max-w-2xl text-sm leading-relaxed text-muted-foreground">
            Additional NCGA publication and workflow work is summarized on the
            resume; published case studies cover shipped product and template
            systems.
          </p>
          <div class="mt-8 divide-y">
            {upcomingCaseStudies.map((project) => (
              <article class="grid gap-6 py-8 md:grid-cols-[14rem_1fr]">
                <ProjectPreview
                  project={project}
                  widths={[360, 600]}
                  sizes="(min-width: 768px) 224px, 100vw"
                />
                <div>
                  <div class="mb-3 flex flex-wrap items-center gap-x-3 gap-y-2">
                    <ProjectDisciplines
                      disciplines={project.disciplines}
                      label={`${project.title} disciplines`}
                    />
                    <Badge variant="outline" className="text-muted-foreground">
                      Coming soon
                    </Badge>
                  </div>
                  <h3 class="text-xl font-bold tracking-tight">
                    {project.title}
                  </h3>
                  <p class="mt-3 max-w-2xl text-sm leading-relaxed text-muted-foreground">
                    {project.summary}
                  </p>
                </div>
              </article>
            ))}
          </div>
        </section>
      )
    }

    <section class="mt-14 pt-12" aria-labelledby="visual-work-title">
      <Separator className="-mt-12 mb-12" />
      <h2 id="visual-work-title" class="text-2xl font-bold tracking-tight">
        Selected visual work
      </h2>
      <div class="mt-8 divide-y">
        {
          visualWork.map((project) => (
            <a
              href={`/projects/${project.slug}`}
              aria-label={`View ${project.title}`}
              class="group grid gap-6 rounded-sm py-8 focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-4 focus-visible:outline-none md:grid-cols-[14rem_1fr]"
            >
              <ProjectPreview
                project={project}
                widths={[360, 600]}
                sizes="(min-width: 768px) 224px, 100vw"
              />
              <div>
                <div class="mb-3 flex flex-wrap items-center gap-x-3 gap-y-2">
                  <ProjectDisciplines
                    disciplines={project.disciplines}
                    label={`${project.title} disciplines`}
                  />
                </div>
                <h3 class="text-xl font-bold tracking-tight group-hover:underline">
                  {project.title}
                </h3>
                <p class="mt-3 max-w-2xl text-sm leading-relaxed text-muted-foreground">
                  {project.summary}
                </p>
              </div>
            </a>
          ))
        }
      </div>
    </section>
  </div>
</Layout>
