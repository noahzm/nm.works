---
import Layout from "@/layouts/main.astro"
import ProjectPreview from "@/components/ProjectPreview.astro"
import ProjectDisciplines from "@/components/ProjectDisciplines.astro"
import SectionHeader from "@/components/SectionHeader.astro"
import Badge from "@/components/ui/badge.astro"
import Separator from "@/components/ui/separator.astro"
import {
  publishedCaseStudies,
  upcomingCaseStudies,
  visualWork,
} from "@/data/projects"
---

<Layout
  title="Projects · Noah Michaels"
  description="Product Designer case studies spanning product UX, interaction design, information architecture, print and variable-data systems, and shipped front-end code by Noah Michaels."
>
  <div class="content-shell pt-4 pb-14">
    <section aria-labelledby="case-studies-title">
      <h1 id="case-studies-title" class="section-title">Case studies</h1>
      <div class="mt-8 divide-y">
        {
          publishedCaseStudies.map((project) => (
            <a
              href={`/projects/${project.slug}`}
              aria-label={`View ${project.title}`}
              class="group project-listing-link"
            >
              <ProjectPreview
                project={project}
                widths={[360, 600]}
                sizes="(min-width: 768px) 224px, 100vw"
              />
              <div>
                <div class="mb-3 flex flex-wrap items-center gap-x-3 gap-y-2">
                  <ProjectDisciplines
                    disciplines={project.disciplines}
                    label={`${project.title} disciplines`}
                  />
                </div>
                <h3 class="text-xl font-bold group-hover:underline">
                  {project.title}
                </h3>
                <p class="mt-3 max-w-2xl text-sm text-muted-foreground">
                  {project.teaser ?? project.summary}
                </p>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    {
      upcomingCaseStudies.length > 0 && (
        <section class="mt-14 pt-12" aria-labelledby="upcoming-title">
          <Separator class="-mt-12 mb-12" />
          <SectionHeader
            titleId="upcoming-title"
            title="In progress"
            description="Additional case studies are in progress. Published entries focus on shipped product and systems work."
          />
          <div class="mt-8 divide-y">
            {upcomingCaseStudies.map((project) => (
              <article class="grid gap-6 py-8 md:grid-cols-[14rem_1fr]">
                <ProjectPreview
                  project={project}
                  widths={[360, 600]}
                  sizes="(min-width: 768px) 224px, 100vw"
                />
                <div>
                  <div class="mb-3 flex flex-wrap items-center gap-x-3 gap-y-2">
                    <ProjectDisciplines
                      disciplines={project.disciplines}
                      label={`${project.title} disciplines`}
                    />
                    <Badge variant="outline" class="text-muted-foreground">
                      Coming soon
                    </Badge>
                  </div>
                  <h3 class="text-xl font-bold">{project.title}</h3>
                  <p class="mt-3 max-w-2xl text-sm text-muted-foreground">
                    {project.teaser ?? project.summary}
                  </p>
                </div>
              </article>
            ))}
          </div>
        </section>
      )
    }

    <section class="mt-14 pt-12" aria-labelledby="visual-work-title">
      <Separator class="-mt-12 mb-12" />
      <SectionHeader titleId="visual-work-title" title="Selected visual work" />
      <div class="mt-8 divide-y">
        {
          visualWork.map((project) => (
            <a
              href={`/projects/${project.slug}`}
              aria-label={`View ${project.title}`}
              class="group project-listing-link"
            >
              <ProjectPreview
                project={project}
                widths={[360, 600]}
                sizes="(min-width: 768px) 224px, 100vw"
              />
              <div>
                <div class="mb-3 flex flex-wrap items-center gap-x-3 gap-y-2">
                  <ProjectDisciplines
                    disciplines={project.disciplines}
                    label={`${project.title} disciplines`}
                  />
                </div>
                <h3 class="text-xl font-bold group-hover:underline">
                  {project.title}
                </h3>
                <p class="mt-3 max-w-2xl text-sm text-muted-foreground">
                  {project.teaser ?? project.summary}
                </p>
              </div>
            </a>
          ))
        }
      </div>
    </section>
  </div>
</Layout>
