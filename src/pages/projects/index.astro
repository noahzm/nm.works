---
import { Picture } from "astro:assets"
import Layout from "@/layouts/main.astro"
import { AspectRatio } from "@/components/ui/aspect-ratio"
import { Badge } from "@/components/ui/badge"
import { Separator } from "@/components/ui/separator"
import {
  publishedCaseStudies,
  upcomingCaseStudies,
  visualWork,
} from "@/data/projects"
---

<Layout
  title="Projects · Noah Michaels"
  description="Product design, accessibility, front-end implementation, and selected visual work by Noah Michaels."
>
  <div class="mx-auto max-w-3xl px-6 pt-4 pb-14">
    <section aria-labelledby="case-studies-title">
      <h1 id="case-studies-title" class="text-2xl font-bold tracking-tight">
        Case studies
      </h1>
      <div class="mt-8 divide-y">
        {
          publishedCaseStudies.map((project) => (
            <a
              href={`/projects/${project.slug}`}
              aria-label={`View ${project.title}`}
              class="group grid gap-6 rounded-sm py-8 focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-4 focus-visible:outline-none md:grid-cols-[14rem_1fr]"
            >
              {project.image && project.imageAlt && (
                <div class="overflow-hidden rounded-md border">
                  <AspectRatio ratio={4 / 3}>
                    <Picture
                      src={project.image}
                      formats={["avif", "webp"]}
                      widths={[360, 600]}
                      sizes="(min-width: 768px) 224px, 100vw"
                      alt=""
                      class="h-full w-full object-cover"
                    />
                  </AspectRatio>
                </div>
              )}
              <div>
                <div class="mb-3 flex flex-wrap items-center gap-3">
                  <p class="text-xs font-bold tracking-[0.18em] text-muted-foreground uppercase">
                    {project.meta}
                  </p>
                </div>
                <h3 class="text-xl font-bold tracking-tight group-hover:underline">
                  {project.title}
                </h3>
                <p class="mt-3 max-w-2xl text-sm leading-relaxed text-muted-foreground">
                  {project.summary}
                </p>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <section class="mt-14 pt-12" aria-labelledby="upcoming-title">
      <Separator className="-mt-12 mb-12" />
      <h2 id="upcoming-title" class="text-2xl font-bold tracking-tight">
        In progress
      </h2>
      <div class="mt-8 divide-y">
        {
          upcomingCaseStudies.map((project) => (
            <article class="grid gap-6 py-8 md:grid-cols-[14rem_1fr]">
              {project.image && project.imageAlt ? (
                <div class="overflow-hidden rounded-md border">
                  <AspectRatio ratio={4 / 3}>
                    <Picture
                      src={project.image}
                      formats={["avif", "webp"]}
                      widths={[360, 600]}
                      sizes="(min-width: 768px) 224px, 100vw"
                      alt=""
                      class="h-full w-full object-cover"
                    />
                  </AspectRatio>
                </div>
              ) : (
                <div class="hidden rounded-md border bg-muted md:block">
                  <AspectRatio ratio={4 / 3} />
                </div>
              )}
              <div>
                <div class="mb-3 flex flex-wrap items-center gap-3">
                  <p class="text-xs font-bold tracking-[0.18em] text-muted-foreground uppercase">
                    {project.meta}
                  </p>
                  <Badge variant="outline" className="text-muted-foreground">
                    Coming soon
                  </Badge>
                </div>
                <h3 class="text-xl font-bold tracking-tight">
                  {project.title}
                </h3>
                <p class="mt-3 max-w-2xl text-sm leading-relaxed text-muted-foreground">
                  {project.summary}
                </p>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="mt-14 pt-12" aria-labelledby="visual-work-title">
      <Separator className="-mt-12 mb-12" />
      <h2 id="visual-work-title" class="text-2xl font-bold tracking-tight">
        Selected visual work
      </h2>
      <div class="mt-8 divide-y">
        {
          visualWork.map((project) => (
            <a
              href={`/projects/${project.slug}`}
              aria-label={`View ${project.title}`}
              class="group grid gap-6 rounded-sm py-8 focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-4 focus-visible:outline-none md:grid-cols-[14rem_1fr]"
            >
              {project.image && project.imageAlt && (
                <div class="overflow-hidden rounded-md border">
                  <AspectRatio ratio={4 / 3}>
                    <Picture
                      src={project.image}
                      formats={["avif", "webp"]}
                      widths={[360, 600]}
                      sizes="(min-width: 768px) 224px, 100vw"
                      alt=""
                      class="h-full w-full object-cover"
                    />
                  </AspectRatio>
                </div>
              )}
              <div>
                <p class="mb-3 text-xs font-bold tracking-[0.18em] text-muted-foreground uppercase">
                  {project.meta}
                </p>
                <h3 class="text-xl font-bold tracking-tight group-hover:underline">
                  {project.title}
                </h3>
                <p class="mt-3 max-w-2xl text-sm leading-relaxed text-muted-foreground">
                  {project.summary}
                </p>
              </div>
            </a>
          ))
        }
      </div>
    </section>
  </div>
</Layout>
