---
import { Picture } from "astro:assets"
import Layout from "@/layouts/main.astro"
import { AspectRatio } from "@/components/ui/aspect-ratio"
import { Separator } from "@/components/ui/separator"
import { getProject } from "@/data/projects"

const selectedWork = [
  getProject("wheely-weather")!,
  getProject("ncga-template-system")!,
  getProject("creative-printing-job-submission-portal")!,
]
---

<Layout>
  <div class="mx-auto max-w-3xl px-6 pt-4 pb-12 sm:pb-16">
    <section class="pb-10 md:pb-14">
      <h1 class="text-3xl font-bold tracking-tight md:text-4xl">
        Product designer
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-relaxed text-muted-foreground">
        I design interfaces that make dense, complicated information clear and
        actionable. My background in print systems and front-end development
        means I can prototype and ship what I design, not just hand it off.
        Looking for a product design role where that matters.
      </p>
    </section>
    <Separator />

    <section class="py-12" aria-labelledby="work-title">
      <div class="mb-10">
        <h2 id="work-title" class="text-2xl font-bold tracking-tight">
          Selected work
        </h2>
      </div>

      <div class="grid grid-cols-1 gap-y-14">
        {
          selectedWork.map((project, index) => (
            <a
              href={`/projects/${project.slug}`}
              aria-label={`View ${project.title}`}
              class="group block rounded-sm focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-4 focus-visible:outline-none"
            >
              <div class="mb-5 flex items-start justify-between gap-4">
                <div>
                  <h3 class="text-xl font-bold tracking-tight group-hover:underline">
                    {project.title}
                  </h3>
                  <p class="mt-2 max-w-prose text-sm leading-relaxed text-muted-foreground">
                    {project.summary}
                  </p>
                </div>
                <span class="shrink-0 text-sm text-muted-foreground tabular-nums">
                  {project.year}
                </span>
              </div>
              {project.image && project.imageAlt && (
                <div class="overflow-hidden rounded-md border bg-muted">
                  <AspectRatio ratio={4 / 3}>
                    <Picture
                      src={project.image}
                      formats={["avif", "webp"]}
                      widths={[600, 1000]}
                      sizes="(min-width: 768px) 768px, 100vw"
                      alt=""
                      loading={index === 0 ? "eager" : "lazy"}
                      class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.025]"
                    />
                  </AspectRatio>
                </div>
              )}
            </a>
          ))
        }
      </div>
    </section>
  </div>
</Layout>
