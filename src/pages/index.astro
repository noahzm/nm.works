---
import Layout from "@/layouts/main.astro"
import ProjectPreview from "@/components/ProjectPreview.astro"
import CTA from "@/components/CTA.astro"
import Separator from "@/components/ui/separator.astro"
import { getProject } from "@/data/projects"

const selectedWork = [
  getProject("wheely-weather")!,
  getProject("ncga-stationery-templates")!,
  getProject("creative-printing-order-flow")!,
]

const proofPoints = [
  "Workflow UX",
  "Working prototypes",
  "Internal tools",
  "Production systems",
  "Design systems",
]

const projectImpacts: Record<string, string> = {
  "ncga-stationery-templates":
    "Replaced fragile per-legislator files with one controlled workflow covering all 170 members.",
  "wheely-weather":
    "Turned raw forecast data into clear ride-quality verdicts across iOS, Android, and web from one Expo codebase.",
  "creative-printing-order-flow":
    "Replaced open-ended service browsing with a grid that routes customers straight to the right order form.",
}
---

<Layout>
  <div class="mx-auto max-w-3xl px-6 pt-4 pb-12 sm:pb-16">
    <section class="pb-10 md:pb-14">
      <h1 class="max-w-3xl text-xl leading-relaxed text-foreground">
        I’m a design technologist who designs and builds in code. I make
        internal tools, production systems, and interfaces where the details
        have to be right.
      </h1>
      <p class="mt-5 max-w-2xl text-base leading-relaxed text-muted-foreground">
        I take a project from interface design through front-end code myself,
        across both digital products and print production.
      </p>
      <ul
        class="mt-8 flex flex-wrap gap-x-4 gap-y-2 text-sm text-muted-foreground"
        aria-label="Portfolio focus areas"
      >
        {
          proofPoints.map((point) => (
            <li class="flex items-center gap-2">
              <span class="h-1.5 w-1.5 rounded-full bg-foreground/70" />
              <span>{point}</span>
            </li>
          ))
        }
      </ul>
    </section>
    <Separator />

    <section class="py-12" aria-labelledby="work-title">
      <div class="mb-10">
        <h2 id="work-title" class="text-2xl font-bold tracking-tight">
          Selected work
        </h2>
        <p class="mt-3 max-w-2xl text-sm leading-relaxed text-muted-foreground">
          Internal tools, independent products, and web projects built around
          real production constraints.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-y-14">
        {
          selectedWork.map((project) => (
            <a
              href={`/projects/${project.slug}`}
              aria-label={`View ${project.title}`}
              class="group block rounded-sm focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-4 focus-visible:outline-none"
            >
              <div class="mb-5 flex items-start justify-between gap-4">
                <div>
                  <h3 class="text-xl font-bold tracking-tight group-hover:underline">
                    {project.title}
                  </h3>
                  <p class="mt-2 max-w-prose text-sm leading-relaxed text-muted-foreground">
                    {project.summary}
                  </p>
                  <p class="mt-3 max-w-prose text-sm leading-relaxed text-foreground">
                    <span class="font-bold">Impact:</span>{" "}
                    {projectImpacts[project.slug]}
                  </p>
                </div>
                <span class="shrink-0 text-sm text-muted-foreground tabular-nums">
                  {project.year}
                </span>
              </div>
              <ProjectPreview
                project={project}
                widths={[600, 1000]}
                sizes="(min-width: 768px) 768px, 100vw"
              />
            </a>
          ))
        }
      </div>

      <div class="mt-12 flex flex-wrap items-baseline gap-x-6 gap-y-3">
        <a
          href="/projects"
          class="-my-3 inline-block rounded-sm py-3 text-sm font-normal text-muted-foreground transition-colors hover:text-foreground focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-4 focus-visible:outline-none"
        >
          All work →
        </a>
        <a
          href="https://github.com/noahzm/nm.works"
          target="_blank"
          rel="noreferrer"
          class="-my-3 inline-block rounded-sm py-3 text-sm text-muted-foreground transition-colors hover:text-foreground focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-4 focus-visible:outline-none"
        >
          View this site’s source on GitHub
        </a>
      </div>
    </section>

    <CTA
      description="Open to design technologist and design engineering roles where I can take an idea from design through to working front-end code."
    />
  </div>
</Layout>
