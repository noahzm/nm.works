---
import Layout from "@/layouts/main.astro"
import ProjectPreview from "@/components/ProjectPreview.astro"
import CTA from "@/components/CTA.astro"
import SectionHeader from "@/components/SectionHeader.astro"
import Separator from "@/components/ui/separator.astro"
import { getProject } from "@/data/projects"

const selectedWork = [
  getProject("wheely-weather")!,
  getProject("ncga-stationery-templates")!,
  getProject("creative-printing-order-flow")!,
]

const projectImpacts: Record<string, string> = {
  "ncga-stationery-templates":
    "Replaced a folder of fragmented files with one template system that produces compliant, print-accurate stationery for all 170 members of the NC legislature.",
  "wheely-weather":
    "Turned raw forecast data into a clear go/no-go ride verdict, so cyclists get an answer at a glance instead of a wall of numbers.",
  "creative-printing-order-flow":
    "Replaced open-ended service browsing with a simple grid of entry points, so customers reach the right order form faster.",
}
---

<Layout>
  <div class="content-shell pt-4 pb-12 sm:pb-16">
    <section class="pb-10 md:pb-14" aria-label="About">
      <h1 class="max-w-3xl text-xl leading-relaxed text-foreground">
        I’m a product designer who also writes production code.
      </h1>
      <p class="mt-4 max-w-3xl text-base leading-relaxed text-muted-foreground">
        I design interfaces, information architecture, and internal tools, then
        build them, so what ships looks and works the way it was designed.
      </p>
      <p class="mt-3 max-w-3xl text-base leading-relaxed text-muted-foreground">
        Right now that means a stationery template system for the North
        Carolina General Assembly print shop and Wheely Weather, a cycling
        weather app I designed and built for iOS, Android, and web.
      </p>
      <p class="mt-3 max-w-3xl text-base leading-relaxed text-muted-foreground">
        I’m based in Raleigh, NC, with a degree in Graphic Arts &amp; Imaging
        Technology from Appalachian State University.
      </p>
    </section>
    <Separator />

    <section class="py-12" aria-labelledby="work-title">
      <SectionHeader
        titleId="work-title"
        title="Selected work"
        description="Case studies across product UI, internal tools, and print systems. All of it shipped."
      />

      <div class="mt-10 grid grid-cols-1 gap-y-14">
        {
          selectedWork.map((project, index) => (
            <a
              href={`/projects/${project.slug}`}
              aria-label={`View ${project.title}`}
              class="group block rounded-sm focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-4 focus-visible:outline-none"
            >
              <div class="mb-5 flex items-start justify-between gap-4">
                <div>
                  <h3 class="text-xl font-bold group-hover:underline">
                    {project.title}
                  </h3>
                  <p class="mt-2 max-w-prose text-sm text-muted-foreground">
                    {project.teaser ?? project.summary}
                  </p>
                  <p class="mt-2 max-w-prose text-sm text-foreground">
                    <span class="font-bold">Outcome:</span>{" "}
                    {projectImpacts[project.slug]}
                  </p>
                </div>
                <span class="shrink-0 text-sm text-muted-foreground tabular-nums">
                  {project.year}
                </span>
              </div>
              <ProjectPreview
                project={project}
                widths={[600, 1000]}
                sizes="(min-width: 768px) 768px, 100vw"
                priority={index === 0}
              />
            </a>
          ))
        }
      </div>

      <div class="mt-12 flex flex-wrap items-baseline gap-x-6 gap-y-3">
        <a href="/projects" class="subtle-link font-normal"> All work → </a>
        <a
          href="https://github.com/noahzm/nm.works"
          target="_blank"
          rel="noreferrer"
          class="subtle-link"
        >
          View this site’s source on GitHub
        </a>
      </div>
    </section>

    <CTA
      description="Open to product design, UX, and design engineering roles. I’m at my best taking a rough idea all the way to polished, shipped software."
    />
  </div>
</Layout>
