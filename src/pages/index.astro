---
import Layout from "@/layouts/main.astro"
import ProjectPreview from "@/components/ProjectPreview.astro"
import CTA from "@/components/CTA.astro"
import SectionHeader from "@/components/SectionHeader.astro"
import Separator from "@/components/ui/separator.astro"
import { getProject } from "@/data/projects"

const selectedWork = [
  getProject("wheely-weather")!,
  getProject("ncga-stationery-templates")!,
  getProject("creative-printing-order-flow")!,
]

const projectImpacts: Record<string, string> = {
  "ncga-stationery-templates":
    "Engineered a centralized, component-based template system that replaced fragmented files with a unified cross-functional workflow, maintaining strict compliance and print-accurate output for all 170 members.",
  "wheely-weather":
    "Architected a logic-driven, verdict-first experience that automates ride decisions, so cyclists can assess multi-variable conditions instantly instead of parsing raw forecast streams.",
  "creative-printing-order-flow":
    "Optimized the information architecture by replacing open-ended service browsing with an intuitive grid-based intake path, reducing ordering friction for commercial customers.",
}
---

<Layout>
  <div class="content-shell pt-4 pb-12 sm:pb-16">
    <section class="pb-10 md:pb-14">
      <h1 class="max-w-3xl text-xl leading-relaxed text-foreground">
        I’m a Technical Product Designer who bridges the gap between complex
        interface design and functional code. I architect intuitive user
        experiences, scalable design systems, and automated internal tools where
        decision clarity and visual craft both matter.
      </h1>
    </section>
    <Separator />

    <section class="py-12" aria-labelledby="work-title">
      <SectionHeader
        titleId="work-title"
        title="Selected work"
        description="Case studies and shipped work across product UI, internal tooling, information architecture, and variable-data systems."
      />

      <div class="mt-10 grid grid-cols-1 gap-y-14">
        {
          selectedWork.map((project, index) => (
            <a
              href={`/projects/${project.slug}`}
              aria-label={`View ${project.title}`}
              class="group block rounded-sm focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-4 focus-visible:outline-none"
            >
              <div class="mb-5 flex items-start justify-between gap-4">
                <div>
                  <h3 class="text-xl font-bold group-hover:underline">
                    {project.title}
                  </h3>
                  <p class="mt-2 max-w-prose text-sm text-muted-foreground">
                    {project.teaser ?? project.summary}
                  </p>
                  <p class="mt-2 max-w-prose text-sm text-foreground">
                    <span class="font-bold">Outcome:</span>{" "}
                    {projectImpacts[project.slug]}
                  </p>
                </div>
                <span class="shrink-0 text-sm text-muted-foreground tabular-nums">
                  {project.year}
                </span>
              </div>
              <ProjectPreview
                project={project}
                widths={[600, 1000]}
                sizes="(min-width: 768px) 768px, 100vw"
                priority={index === 0}
              />
            </a>
          ))
        }
      </div>

      <div class="mt-12 flex flex-wrap items-baseline gap-x-6 gap-y-3">
        <a href="/projects" class="subtle-link font-normal"> All work → </a>
        <a
          href="https://github.com/noahzm/nm.works"
          target="_blank"
          rel="noreferrer"
          class="subtle-link"
        >
          View this site’s source on GitHub
        </a>
      </div>
    </section>

    <CTA
      description="Open to Technical Product Design and Design Engineering roles where I can take an ambiguous idea from concept to polished, production-ready software."
    />
  </div>
</Layout>
