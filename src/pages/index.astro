---
import { Picture } from "astro:assets"
import Layout from "@/layouts/main.astro"
import { publishedCaseStudies, visualWork } from "@/data/projects"

const selectedWork = [
  publishedCaseStudies.find((project) => project.slug === "wheely-weather")!,
  ...publishedCaseStudies.filter(
    (project) => project.slug !== "wheely-weather"
  ),
  ...visualWork.filter((project) => project.status === "published"),
]
---

<Layout>
  <section class="px-6 pt-4">
    <div class="mx-auto max-w-5xl border-b border-border pb-10 md:pb-14">
      <h1 class="text-3xl font-bold tracking-tight md:text-4xl">
        Product designer
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-relaxed text-muted-foreground">
        I’m a Raleigh-based product designer creating clear digital experiences
        for complex content, workflows, and accessible web interfaces, with
        enough front-end fluency to carry the work into production.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-6 py-12" aria-labelledby="work-title">
    <div class="mb-10">
      <h2 id="work-title" class="text-2xl font-bold tracking-tight">
        Selected work
      </h2>
    </div>

    <div class="grid grid-cols-1 gap-x-8 gap-y-14 md:grid-cols-2">
      {
        selectedWork.map((project, index) => (
          <a
            href={`/projects/${project.slug}`}
            aria-label={`View ${project.title}`}
            class="group block rounded-sm focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-4 focus-visible:outline-none"
          >
            <div class="mb-5 flex items-start justify-between gap-4">
              <div>
                <h3 class="text-xl font-bold tracking-tight group-hover:underline">
                  {project.title}
                </h3>
                <p class="mt-2 max-w-prose text-sm leading-relaxed text-muted-foreground">
                  {project.summary}
                </p>
              </div>
              <span class="shrink-0 text-sm text-muted-foreground tabular-nums">
                {project.year}
              </span>
            </div>
            {project.image && project.imageAlt && (
              <div class="overflow-hidden rounded-md border bg-muted">
                <Picture
                  src={project.image}
                  formats={["avif", "webp"]}
                  widths={[600, 1000]}
                  sizes="(min-width: 768px) 480px, 100vw"
                  alt=""
                  loading={index === 0 ? "eager" : "lazy"}
                  class="aspect-[4/3] h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.025]"
                />
              </div>
            )}
          </a>
        ))
      }
    </div>
  </section>
</Layout>
