---
import Layout from "@/layouts/main.astro"
import ProjectPreview from "@/components/ProjectPreview.astro"
import CTA from "@/components/CTA.astro"
import { Separator } from "@/components/ui/separator"
import { getProject } from "@/data/projects"

const selectedWork = [
  getProject("ncga-stationery-templates")!,
  getProject("wheely-weather")!,
]
---

<Layout>
  <div class="mx-auto max-w-3xl px-6 pt-4 pb-12 sm:pb-16">
    <section class="pb-10 md:pb-14">
      <h1 class="max-w-3xl text-xl leading-relaxed text-foreground">
        I’m a designer and front-end builder with a production background. I’m
        comfortable turning unclear requirements into usable websites, workflow
        tools, print systems, and carefully finished files.
      </h1>
    </section>
    <Separator />

    <section class="py-12" aria-labelledby="work-title">
      <div class="mb-10">
        <h2 id="work-title" class="text-2xl font-bold tracking-tight">
          Selected work
        </h2>
        <p class="mt-3 max-w-2xl text-sm leading-relaxed text-muted-foreground">
          Selected work across internal workflow tools, independent product
          builds, and production-heavy web projects.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-y-14">
        {
          selectedWork.map((project) => (
            <a
              href={`/projects/${project.slug}`}
              aria-label={`View ${project.title}`}
              class="group block rounded-sm focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-4 focus-visible:outline-none"
            >
              <div class="mb-5 flex items-start justify-between gap-4">
                <div>
                  <h3 class="text-xl font-bold tracking-tight group-hover:underline">
                    {project.title}
                  </h3>
                  <p class="mt-2 max-w-prose text-sm leading-relaxed text-muted-foreground">
                    {project.summary}
                  </p>
                </div>
                <span class="shrink-0 text-sm text-muted-foreground tabular-nums">
                  {project.year}
                </span>
              </div>
              <ProjectPreview
                project={project}
                widths={[600, 1000]}
                sizes="(min-width: 768px) 768px, 100vw"
              />
            </a>
          ))
        }
      </div>

      <div class="mt-12">
        <a
          href="/projects"
          class="-my-3 inline-block rounded-sm py-3 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-4 focus-visible:outline-none"
        >
          All work →
        </a>
      </div>
    </section>

    <CTA
      description="Open to roles involving front-end implementation, design production, workflow tools, or print/digital production systems."
    />
  </div>
</Layout>
