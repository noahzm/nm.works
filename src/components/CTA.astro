---
import { Icon } from "astro-icon/components"
import { buttonVariants } from "@/components/ui/button-variants"
import Separator from "@/components/ui/separator.astro"

interface Props {
  title?: string
  description: string
  href?: string
  label?: string
}

const {
  title = "Let\u2019s build something useful.",
  description,
  href = "mailto:hi@nm.works?subject=Hi%20from%20nm.works",
  label = "Start a conversation",
} = Astro.props
---

<section class="py-12">
  <Separator />
  <div
    class="flex flex-col gap-6 pt-12 sm:flex-row sm:items-end sm:justify-between"
  >
    <div class="max-w-xl">
      <h2 class="section-title">{title}</h2>
      <p class="mt-3 text-base leading-relaxed text-muted-foreground">
        {description}
      </p>
    </div>
    <a
      href={href}
      data-slot="button"
      data-variant="default"
      data-size="default"
      class={buttonVariants({ variant: "default", className: "w-fit" })}
    >
      <Icon
        name="lucide:message-circle"
        aria-hidden="true"
        data-affix="inline-start"
        class="[&_path]:fill-current [&_path]:[stroke-width:1.5]"
      />
      {label}
    </a>
  </div>
</section>
