---
import { buttonVariants } from "@/components/ui/button-variants"
import { Separator } from "@/components/ui/separator"

interface Props {
  title?: string
  description: string
  href?: string
  label?: string
}

const {
  title = "Let’s make complex work easier to use.",
  description,
  href = "mailto:hi@nm.works?subject=Hi%20from%20nm.works",
  label = "Start a conversation",
} = Astro.props
---

<section class="py-12">
  <Separator />
  <div
    class="flex flex-col gap-6 pt-12 sm:flex-row sm:items-end sm:justify-between"
  >
    <div class="max-w-xl">
      <h2 class="text-2xl font-bold tracking-tight">{title}</h2>
      <p class="mt-3 text-base leading-relaxed text-muted-foreground">
        {description}
      </p>
    </div>
    <a
      href={href}
      data-slot="button"
      data-variant="outline"
      data-size="default"
      class={buttonVariants({ variant: "outline", className: "w-fit" })}
    >
      {label}
    </a>
  </div>
</section>
