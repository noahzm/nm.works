---
import { Badge } from "@/components/ui/badge"
import { disciplineLabels, type ProjectDiscipline } from "@/data/projects"

interface Props {
  disciplines: ProjectDiscipline[]
  label: string
  class?: string
}

const { disciplines, label, class: className } = Astro.props

const disciplineClasses: Record<ProjectDiscipline, string> = {
  "product-design":
    "border-[oklch(0.84_0.05_24)] bg-[oklch(0.97_0.02_24)] text-[oklch(0.38_0.08_24)]",
  "front-end":
    "border-[oklch(0.82_0.06_215)] bg-[oklch(0.97_0.02_215)] text-[oklch(0.34_0.08_215)]",
  "ux-ui":
    "border-[oklch(0.82_0.06_150)] bg-[oklch(0.97_0.02_150)] text-[oklch(0.34_0.08_150)]",
  "information-architecture":
    "border-[oklch(0.84_0.06_82)] bg-[oklch(0.98_0.03_82)] text-[oklch(0.39_0.08_82)]",
  "public-sector-design-system":
    "border-[oklch(0.84_0.05_285)] bg-[oklch(0.97_0.02_285)] text-[oklch(0.36_0.08_285)]",
  "brand-apparel":
    "border-[oklch(0.84_0.05_340)] bg-[oklch(0.97_0.02_340)] text-[oklch(0.38_0.08_340)]",
}
---

<ul class:list={["flex flex-wrap gap-2", className]} aria-label={label}>
  {
    disciplines.map((discipline) => (
      <li>
        <Badge variant="outline" className={disciplineClasses[discipline]}>
          {disciplineLabels[discipline]}
        </Badge>
      </li>
    ))
  }
</ul>
