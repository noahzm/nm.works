---
import Badge from "@/components/ui/badge.astro"
import { disciplineLabels, type ProjectDiscipline } from "@/data/projects"

interface Props {
  disciplines: ProjectDiscipline[]
  label: string
  class?: string
}

const { disciplines, label, class: className } = Astro.props
---

<ul class:list={["flex flex-wrap gap-2", className]} aria-label={label}>
  {
    disciplines.map((discipline) => (
      <li>
        <Badge variant="outline" class="text-muted-foreground">
          {disciplineLabels[discipline]}
        </Badge>
      </li>
    ))
  }
</ul>
