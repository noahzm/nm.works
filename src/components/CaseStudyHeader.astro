---
import { Picture } from "astro:assets"
import { ArrowLeft } from "lucide-react"
import ExternalArrow from "@/components/ExternalArrow.astro"
import ProjectDisciplines from "@/components/ProjectDisciplines.astro"
import { buttonVariants } from "@/components/ui/button-variants"
import type { Project, ProjectHeaderLink } from "@/data/projects"

interface Props {
  project: Project
  title?: string
  description?: string
}

interface MetadataItem {
  label: string
  value: string
  fullWidth?: boolean
}

const {
  project,
  title = project.title,
  description = project.description,
} = Astro.props

const metadataItems: MetadataItem[] = [
  { label: "Role", value: project.role },
  { label: "Year", value: project.year },
  ...(project.status === "coming-soon"
    ? [{ label: "Status", value: "In progress" }]
    : []),
  ...(project.headerDetails?.map((item, _, items) => ({
    ...item,
    fullWidth: items.length === 1,
  })) ?? []),
]

const hasHeaderLinks =
  project.appStoreUrl ||
  project.liveUrl ||
  project.githubUrl ||
  (project.headerLinks && project.headerLinks.length > 0)

function isExternalLink(link: ProjectHeaderLink) {
  return link.external !== false && !link.href.startsWith("#")
}
---

<header class="mb-10 sm:mb-12">
  <a
    href="/projects"
    class="-my-3 mb-4 inline-flex items-center gap-1 rounded-sm py-3 text-sm text-muted-foreground transition-colors hover:text-foreground focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-4 focus-visible:outline-none [&_svg]:size-3.5 [&_svg]:shrink-0"
  >
    <ArrowLeft aria-hidden="true" data-icon="inline-start" strokeWidth={2} />
    Back to projects
  </a>
  <div class="mb-4 flex flex-wrap items-center gap-x-3 gap-y-2">
    <ProjectDisciplines
      disciplines={project.disciplines}
      label={`${project.title} disciplines`}
    />
  </div>
  <h1 class="max-w-3xl text-3xl font-bold tracking-tight sm:text-5xl">
    {title}
  </h1>
  <p class="mt-5 max-w-2xl text-lg leading-relaxed text-muted-foreground">
    {description}
  </p>
  <dl
    class="mt-7 grid max-w-2xl grid-cols-2 gap-x-8 gap-y-4 border-y border-border py-4 text-sm"
  >
    {
      metadataItems.map((item, index) => (
        <div
          class:list={[
            index === 0 && "col-span-2 sm:col-span-1",
            item.fullWidth && "col-span-2",
          ]}
        >
          <dt class="text-muted-foreground">{item.label}</dt>
          <dd
            class:list={[
              "mt-1",
              item.fullWidth
                ? "font-normal leading-relaxed"
                : "font-medium",
            ]}
          >
            {item.value}
          </dd>
        </div>
      ))
    }
  </dl>
  {
    hasHeaderLinks && (
      <div class="mt-5 flex max-w-2xl flex-wrap gap-2">
        {
          project.appStoreUrl && (
            <a
              href={project.appStoreUrl}
              target="_blank"
              rel="noreferrer"
              data-slot="button"
              data-variant="default"
              data-size="sm"
              class={buttonVariants({ variant: "default", size: "sm" })}
            >
              Download on the App Store
              <ExternalArrow />
            </a>
          )
        }
        {
          project.liveUrl && (
            <a
              href={project.liveUrl}
              target="_blank"
              rel="noreferrer"
              data-slot="button"
              data-variant="default"
              data-size="sm"
              class={buttonVariants({ variant: "default", size: "sm" })}
            >
              {project.liveUrlLabel ?? "View web app"}
              <ExternalArrow />
            </a>
          )
        }
        {
          project.githubUrl && (
            <a
              href={project.githubUrl}
              target="_blank"
              rel="noreferrer"
              data-slot="button"
              data-variant="outline"
              data-size="sm"
              class={buttonVariants({ variant: "outline", size: "sm" })}
            >
              View on GitHub
              <ExternalArrow />
            </a>
          )
        }
        {
          project.headerLinks?.map((link) => (
            <a
              href={link.href}
              {...(isExternalLink(link)
                ? { target: "_blank", rel: "noreferrer" }
                : {})}
              data-slot="button"
              data-variant="outline"
              data-size="sm"
              class={buttonVariants({ variant: "outline", size: "sm" })}
            >
              {link.label}
              {isExternalLink(link) && <ExternalArrow />}
            </a>
          ))
        }
      </div>
    )
  }
  {
    project.image && project.imageAlt && (
      <figure class="mt-9 sm:mt-10">
        <Picture
          src={project.image}
          formats={["avif", "webp"]}
          widths={[720, 1200, 1600]}
          sizes="(min-width: 768px) 768px, 100vw"
          alt={project.imageAlt}
          style={
            project.imageObjectPosition
              ? `object-position: ${project.imageObjectPosition}`
              : undefined
          }
          class="aspect-[3/2] w-full rounded-md border object-cover"
        />
      </figure>
    )
  }
</header>
