---
import { ArrowRight } from "lucide-react"
import Layout from "@/layouts/main.astro"
import CaseStudyHeader from "@/components/CaseStudyHeader.astro"
import { Separator } from "@/components/ui/separator"
import { publishedProjects, type Project } from "@/data/projects"

interface Props {
  project: Project
  title?: string
  description?: string
  seoTitle?: string
  seoDescription?: string
}

const {
  project,
  title = project.title,
  description = project.description,
  seoTitle = `${project.title} · Noah Michaels`,
  seoDescription = project.description,
} = Astro.props

const nextProjects = publishedProjects.filter((p) => p.slug !== project.slug)
const next = nextProjects[0] ?? null
---

<Layout
  title={seoTitle}
  description={seoDescription}
  image={project.image?.src}
  ogType="article"
  noindex={project.status === "coming-soon"}
>
  <div class="mx-auto max-w-3xl px-6 pt-2 pb-10 sm:pb-14">
    <CaseStudyHeader
      project={project}
      title={title}
      description={description}
    />
    <article class="case-study">
      <slot />
    </article>

    {
      next && (
        <footer class="mt-16 pt-7 sm:mt-20">
          <Separator className="-mt-7 mb-7" />
          <a
            href={`/projects/${next.slug}`}
            class="group flex items-center justify-between gap-6 rounded-sm focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-4 focus-visible:outline-none [&_svg]:size-4 [&_svg]:shrink-0"
          >
            <span>
              <span class="block text-xs font-bold tracking-[0.18em] text-muted-foreground uppercase">
                Next project
              </span>
              <span class="mt-1 block text-base font-bold tracking-tight transition-colors group-hover:text-muted-foreground">
                View {next.title}
              </span>
            </span>
            <ArrowRight aria-hidden="true" data-icon="inline-end" />
          </a>
        </footer>
      )
    }
  </div>
</Layout>

<style is:global>
  .case-study {
    font-size: 1.0625rem;
    line-height: 1.7;
  }
  .case-study > * + * {
    margin-top: 0.875rem;
  }
  .case-study p {
    max-width: 65ch;
  }
  .case-study h2 {
    margin-top: 3.25rem;
    margin-bottom: 1.125rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted-foreground);
  }
  .case-study h2:first-child {
    margin-top: 0;
  }
  .case-study h3 {
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .case-study ul {
    list-style: disc;
    padding-left: 1.25rem;
  }
  .case-study ul li + li {
    margin-top: 0.375rem;
  }
  .case-study figure {
    margin-top: 1.75rem;
    margin-bottom: 1.75rem;
  }
  .case-study figure img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0.375rem;
    border: 1px solid var(--border);
  }
  .case-study figcaption {
    margin-top: 0.625rem;
    font-size: 0.875rem;
    line-height: 1.5;
    color: color-mix(in oklch, var(--foreground) 82%, var(--background));
  }
</style>
