---
import "@/styles/global.css"
import { ClientRouter } from "astro:transitions"

interface Props {
  title?: string
  description?: string
  image?: string
  ogType?: "website" | "article"
  noindex?: boolean
}

const {
  title = "Noah Michaels · Design Technologist",
  description = "Noah Michaels is a design technologist who designs and builds workflow interfaces, internal tools, and production systems in code, across product UI, information architecture, and front-end implementation.",
  image,
  ogType = "website",
  noindex = false,
} = Astro.props

const canonicalURL = new URL(
  Astro.url.pathname.replace(/\/$/, "") || "/",
  Astro.site ?? Astro.url.origin
)
const socialImageURL = image ? new URL(image, canonicalURL) : null

const headerWidthClass = "max-w-3xl"
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalURL} />
    <meta name="theme-color" content="#ffffff" />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {socialImageURL && <meta property="og:image" content={socialImageURL} />}
    <meta
      name="twitter:card"
      content={socialImageURL ? "summary_large_image" : "summary"}
    />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {socialImageURL && <meta name="twitter:image" content={socialImageURL} />}
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only bg-background text-foreground focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:rounded-sm focus:px-3 focus:py-2 focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:outline-none"
    >
      Skip to content
    </a>
    <header class="px-6 py-10 md:py-14">
      <nav
        class:list={[
          "mx-auto flex flex-col items-baseline gap-4 md:flex-row md:justify-between md:gap-6",
          headerWidthClass,
        ]}
        aria-label="Main navigation"
      >
        <a
          href="/"
          class="rounded-sm text-2xl font-bold tracking-tight transition-colors hover:text-muted-foreground focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-4 focus-visible:outline-none"
        >
          Noah Michaels
        </a>
        <div class="flex items-baseline gap-5">
          <a
            href="/projects"
            class="-my-3 rounded-sm py-3 text-sm text-muted-foreground transition-colors hover:text-foreground focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-4 focus-visible:outline-none"
          >
            Projects
          </a>
          <a
            href="https://github.com/noahzm"
            target="_blank"
            rel="noreferrer"
            class="-my-3 rounded-sm py-3 text-sm text-muted-foreground transition-colors hover:text-foreground focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-4 focus-visible:outline-none"
          >
            GitHub
          </a>
          <a
            href="mailto:hi@nm.works?subject=Hi%20from%20nm.works"
            class="-my-3 rounded-sm py-3 text-sm text-muted-foreground transition-colors hover:text-foreground focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-4 focus-visible:outline-none"
          >
            hi@nm.works
          </a>
        </div>
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
  </body>
</html>
